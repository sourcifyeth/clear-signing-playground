{
  "name": "clear-signing-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:index && npm run build:chain-info && tsc -b && vite build",
    "build:index": "tsx scripts/build-index.ts",
    "build:index:force": "tsx scripts/build-index.ts --force",
    "build:chain-info": "tsx scripts/build-chain-info.ts",
    "build:chain-info:force": "tsx scripts/build-chain-info.ts --force",
    "fix": "npm run fix:prettier && npm run fix:eslint",
    "fix:prettier": "prettier \"**/*.{ts,tsx,js,md,json}\" --write",
    "fix:eslint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\" --fix",
    "check": "npm run check:types && npm run check:prettier && npm run check:eslint",
    "check:types": "tsc -b",
    "check:prettier": "prettier \"**/*.{ts,tsx,js,md,json}\" --check",
    "check:eslint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.0.0",
    "@fontsource/ibm-plex-mono": "^5.0.0",
    "@sourcifyeth/clear-signing": "git+https://github.com/sourcifyeth/clear-signing.git#b2ae3b01b5a5e1fe7c9057873f2025276d29b9b7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  }
}
